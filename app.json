{
  "expo": {
    "name": "Soul Surf",
    "slug": "soul-surf-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/soulsurf.jpg",
    "scheme": "soulsurfmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soulsurfmobile.app"
    },
    "android": {
      "package": "com.soulsurfmobile.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "@maplibre/maplibre-react-native",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir que o Soul Surf use sua localização."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "58df7d1d-2d16-4f7f-83dc-11b9bfab139b"
      }
    }
  }
}
