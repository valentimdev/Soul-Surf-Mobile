{
  "expo": {
    "name": "soul-surf-mobile",
    "slug": "soul-surf-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "soulsurfmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soulsurfmobile.app"
    },
    "android": {
      "package": "com.soulsurfmobile.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "@maplibre/maplibre-react-native",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}